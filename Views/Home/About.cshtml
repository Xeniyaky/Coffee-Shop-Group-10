@{
    ViewData["Title"] = "About";
}

<div class="about-container">
    <h1 class="text-center">About Our Team</h1>

    <div class="team-grid">
        <div class="member">
            <img src="~/images/xeniya.jpg" alt="Xeniya" class="profile-pic" /> <h3>Xeniya Kyrychenko</h3>
            <p class="role">MVC Development & API Integration</p>
        </div>

        <div class="member">
            <img src="~/images/tiffany.jpg" alt="Tiffany" class="profile-pic" /> <h3>Tiffany Kuo Chang</h3>
            <p class="role">UI Design & Styling</p>
        </div>

        <div class="member">
            <img src="~/images/chrisheadshot.jpg" alt="Chris" class="profile-pic" /> <h3>Christodoulos Nikiforou</h3>
            <p class="role">Database Integration</p>
        </div>

        <div class="member">
            <img src="~/images/adanmaheadshot.jpg" alt="Adanma" class="profile-pic" /> <h3>Adanma Okoroafor</h3>
            <p class="role">ERD Design & API Integration</p>
        </div>

    </div>

    <div class="project-summary text-center">
        <h2>About Brew Haven</h2>
        <p>
            Brew Haven is a dynamic ASP.NET MVC coffee shop application. Our mission was to bridge
            the gap between simple order management and real-time nutritional insights, creating a
            powerful tool for both staff and customers.
        </p>
        
        <div class="repo-link-box">
            <h3>Technical Documentation</h3>
            <p>For a deep dive into our API integrations, ERD diagrams, and CRUD implementation, please visit our official repository.</p>
            <a href="https://github.com/Xeniyaky/Coffee-Shop-Group-10/blob/main/README.md" class="btn btn-primary" target="_blank">
                View Technical README on GitHub
            </a>
        </div>
    </div>
</div>

<style>
    .team-grid {
        display: flex;
        justify-content: center;
        flex-wrap: wrap;
        margin-top: 30px;
        gap: 20px;
        max-width: 600px;
        margin-left: auto;
        margin-right: auto;
    }

    .member {
        text-align: center;
        margin: 15px;
        width: calc(50% - 50px);
        min-width: 220px;
    }

    .profile-pic {
        width: 150px;
        height: 150px;
        border-radius: 50%;
        object-fit: cover;
        border: 3px solid #fff;
        background-color: #fff;
        box-shadow: 0 8px 10px -5px rgba(0,0,0,0.3);
        margin-bottom: 10px;
        display: block;
        margin-left: auto;
        margin-right: auto;
    }

    .role {
        font-style: italic;
        color: #555;
    }

    .repo-link-box {
        background-color: #e0d8c8;
        padding: 25px;
        border-radius: 8px;
        margin-top: 40px;
        border: 1px solid #dee2e6;
    }

    .text-center {
        text-align: center;
    }
</style>