@model CoffeeShopMVC.Models.Order

<section class="card p-4 shadow-sm mx-auto" style="max-width: 600px; margin-top: 50px;">
    <h3>Enter Order Information</h3>
    <form asp-action="Create" method="post">
        <div class="mb-3">
            <label class="form-label fw-bold">Customer Name</label>
            <input asp-for="CustomerName" class="form-control" placeholder="Enter name" required />
        </div>

        <div id="items-container">
            <div class="row item-row mb-3">
                <div class="col-md-6">
                    <label class="form-label">Item</label>
                    <input name="DrinkNames" class="form-control" placeholder="e.g. Iced Coffee" required />
                </div>
                <div class="col-md-3">
                    <label class="form-label">Size</label>
                    <select name="Sizes" class="form-control">
                        <option>Small</option>
                        <option>Medium</option>
                        <option>Large</option>
                    </select>
                </div>
                <div class="col-md-2">
                    <label class="form-label">Qty</label>
                    <input name="Quantities" type="number" class="form-control" value="1" min="1" />
                </div>
                <div class="col-md-1"></div>
            </div>
        </div>

        <div class="mt-3 d-flex justify-content-between">
            <button type="button" class="btn btn-outline-secondary btn-sm" onclick="addItem()">+ Add Another Item</button>
            <button type="submit" class="btn btn-brown">Submit Full Order</button>
        </div>
    </form>
</section>

@section Scripts {
    <script>
                function addItem() {
            const container = document.getElementById('items-container');
            const rows = document.querySelectorAll('.item-row');
            const newRow = rows[0].cloneNode(true);

            // 1. Clear the values so it's a fresh row
            newRow.querySelectorAll('input').forEach(input => input.value = '');
            newRow.querySelector('select').selectedIndex = 0;

            // 2. Add the Minus button to the cloned row (if it's not already there)
            // We check if it has a remove-btn already to avoid duplicates
            if (!newRow.querySelector('.remove-btn')) {
                const removeCol = document.createElement('div');
                removeCol.className = 'col-md-1 d-flex align-items-center';
                removeCol.innerHTML = `
                    <button type="button" class="btn btn-link text-danger p-0" onclick="this.closest('.item-row').remove()">
                        <i class="bi bi-dash-circle-fill" style="font-size: 1.5rem;"></i>
                    </button>`;
                newRow.appendChild(removeCol);
            }

            container.appendChild(newRow);
        }
    </script>
}