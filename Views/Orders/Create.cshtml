@model CoffeeShopMVC.Models.Order

<section class="card p-4 shadow-sm mx-auto" style="max-width: 900px; margin-top: 50px; background-color: #fffaf0; border-radius: 20px;">
    <h3 class="mb-4" style="color: #4b3621;">Enter Order Information</h3>

    <form asp-action="Create" method="post">
        <div class="mb-4">
            <label class="form-label fw-bold">Customer Name</label>
            <input asp-for="CustomerName" class="form-control" placeholder="Enter name" required style="border-radius: 10px;" />
        </div>

        <div id="items-container">
            <div class="row fw-bold mb-2 d-none d-md-flex text-center" style="color: #4b3621;">
                <div class="col-md-4">Item</div>
                <div class="col-md-2">Size</div>
                <div class="col-md-2">Qty</div>
                <div class="col-md-3">Price ($)</div>
                <div class="col-md-1"></div>
            </div>

            <div class="row item-row mb-3 align-items-center">
                <div class="col-md-4">
                    <input name="OrderItems[0].DrinkName" class="form-control" placeholder="e.g. Iced Coffee" required />
                </div>
                <div class="col-md-2">
                    <select name="OrderItems[0].Size" class="form-control">
                        <option>Small</option>
                        <option>Medium</option>
                        <option>Large</option>
                    </select>
                </div>
                <div class="col-md-2">
                    <input name="OrderItems[0].Quantity" type="number" class="form-control" value="1" min="1" />
                </div>
                <div class="col-md-3">
                    <input name="OrderItems[0].Price" type="number" step="0.1" class="form-control" placeholder="0.00" required />
                </div>
                <div class="col-md-1"></div>
            </div>
        </div>

        <div class="mt-4 d-flex justify-content-between">
            <button type="button" class="btn btn-outline-secondary" onclick="addItem()" style="border-radius: 10px;">
                <i class="bi bi-plus-circle me-1"></i> Add Another Item
            </button>
            <button type="submit" class="btn btn-brown px-4">Submit Full Order</button>
        </div>
    </form>
</section>

@section Scripts {
    <script>
        function addItem() {
            const container = document.getElementById('items-container');
            const rows = document.querySelectorAll('.item-row');
            const index = rows.length;

            const newRow = document.createElement('div');
            newRow.className = 'row item-row mb-3 align-items-center';
            newRow.innerHTML = `
                <div class="col-md-4">
                    <input name="OrderItems[${index}].DrinkName" class="form-control" placeholder="Item Name" required />
                </div>
                <div class="col-md-2">
                    <select name="OrderItems[${index}].Size" class="form-control">
                        <option>Small</option><option>Medium</option><option>Large</option>
                    </select>
                </div>
                <div class="col-md-2">
                    <input name="OrderItems[${index}].Quantity" type="number" class="form-control" value="1" min="1" />
                </div>
                <div class="col-md-3">
                    <input name="OrderItems[${index}].Price" type="number" step="0.01" class="form-control" placeholder="0.00" required />
                </div>
                <div class="col-md-1">
                    <button type="button" class="btn btn-link text-danger p-0 remove-btn">
                        <i class="bi bi-dash-circle-fill" style="font-size: 1.5rem;"></i>
                    </button>
                </div>`;
            container.appendChild(newRow);
        }
                function reIndexItems() {
            document.querySelectorAll('.item-row').forEach((row, index) => {
                row.querySelectorAll('input, select').forEach(element => {
                    const name = element.getAttribute('name');
                    if (name) {
                        // This regex updates OrderItems[AnyNumber] to the current index
                        element.setAttribute('name', name.replace(/\[\d+\]/g, `[${index}]`));
                    }
                });
            });
        }

        // IMPORTANT: Your delete listener MUST call this
        document.addEventListener('click', function (e) {
            if (e.target.closest('.remove-btn')) {
                e.target.closest('.item-row').remove();
                reIndexItems(); // <--- This fixes the "Jam" bug
            }
        });
    </script>
}