@model CoffeeShopMVC.Models.Order

<main>
  <section class="card">
    <h2>Delete Order</h2>

    <p>Are you sure you want to delete this order?</p>

    <p><strong>Order ID:</strong> @Model.Id</p>
    <p><strong>Customer:</strong> @Model.CustomerName</p>
        <p><strong>Order Summary:</strong></p>
        <ul>
            @if (Model.OrderItems != null && Model.OrderItems.Any())
            {
                foreach (var item in Model.OrderItems)
                {
                    <li>@item.Quantity x @item.DrinkName (@item.Size)</li>
                }
            }
            else
            {
                <li>No items found in this order.</li>
            }
        </ul>
        <p><strong>Total Price:</strong> $@Model.Total.ToString("F2")</p>

        <form asp-action="DeleteConfirmed" method="post">
            <input type="hidden" asp-for="Id" />
            <button type="submit" class="btn btn-brown">Delete Order</button>
            <a asp-action="Index" class="btn btn-secondary">Cancel</a>
        </form>

  </section>
</main>