@model CoffeeShopMVC.Models.Order

<main>
  <section class="card">
    <h2>Delete Order</h2>

    <p>Are you sure you want to delete this order?</p>

    <p><strong>Order ID:</strong> @Model.Id</p>
    <p><strong>Customer:</strong> @Model.CustomerName</p>
    <p><strong>Drink:</strong> @Model.DrinkItem</p>
    <p><strong>Size:</strong> @Model.Size</p>
    <p><strong>Quantity:</strong> @Model.Quantity</p>

    <form asp-action="DeleteConfirmed" method="post">
      <input type="hidden" asp-for="Id" />

      <button type="submit">Delete Order</button>
      <a asp-action="Index" class="btn">Cancel</a>
    </form>

  </section>
</main>