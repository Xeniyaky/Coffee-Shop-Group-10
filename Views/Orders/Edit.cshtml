@model CoffeeShopMVC.Models.Order

<h2>Edit Order</h2>

<form asp-action="Edit">
    <input type="hidden" asp-for="Id" />

    <div class="form-group mb-3">
        <label asp-for="CustomerName" class="control-label fw-bold"></label>
        <input asp-for="CustomerName" class="form-control" />
    </div>

    <div class="mb-4">
        <label class="form-label fw-bold">Items</label>
        <div id="items-container">
            @for (int i = 0; i < Model.OrderItems.Count; i++)
            {
                <div class="row item-row mb-3 align-items-center">
                    <input type="hidden" name="OrderItems[@i].Id" value="@Model.OrderItems[i].Id" />
                    <div class="col-md-4">
                        <input name="OrderItems[@i].DrinkName" value="@Model.OrderItems[i].DrinkName" class="form-control" />
                    </div>
                    <div class="col-md-2">
                        <select name="OrderItems[@i].Size" class="form-control">
                            <option selected="@(Model.OrderItems[i].Size == "Small")">Small</option>
                            <option selected="@(Model.OrderItems[i].Size == "Medium")">Medium</option>
                            <option selected="@(Model.OrderItems[i].Size == "Large")">Large</option>
                        </select>
                    </div>
                    <div class="col-md-2">
                        <input name="OrderItems[@i].Quantity" type="number" class="form-control" value="@Model.OrderItems[i].Quantity" />
                    </div>
                    <div class="col-md-3">
                        <input name="OrderItems[@i].Price" type="number" step="0.01" class="form-control" value="@Model.OrderItems[i].Price" required />
                    </div>
                    <div class="col-md-1">
                        <button type="button" class="btn btn-link text-danger p-0 remove-btn">
                            <i class="bi bi-dash-circle-fill" style="font-size: 1.5rem;"></i>
                        </button>
                    </div>
                </div>
            }
        </div>

        <button type="button" class="btn btn-outline-secondary btn-sm mt-2" onclick="addNewItem()">
            + Add New Item
        </button>
    </div>

    <div class="form-group mt-3">
        <input type="submit" value="Save" class="btn btn-primary" />
        <a asp-action="Index" class="btn btn-secondary">Back to List</a>
    </div>
</form>

@section Scripts{
    <script>
        function addNewItem() {
            const container = document.getElementById('items-container');
            if (!container) {
                console.error("Could not find items-container!");
                return;
            }

            // Count existing rows to get the next index
            const index = document.querySelectorAll('.item-row').length;

            const newRow = document.createElement('div');
            newRow.className = 'row item-row mb-3 align-items-center';
            
            // Note: We do NOT include a hidden ID input for NEW items
            newRow.innerHTML = `
                <div class="col-md-4">
                    <input name="OrderItems[${index}].DrinkName" class="form-control" placeholder="Item Name" required />
                </div>
                <div class="col-md-2">
                    <select name="OrderItems[${index}].Size" class="form-control">
                        <option>Small</option><option>Medium</option><option>Large</option>
                    </select>
                </div>
                <div class="col-md-2">
                    <input name="OrderItems[${index}].Quantity" type="number" class="form-control" value="1" min="1" />
                </div>
                <div class="col-md-3">
                    <input name="OrderItems[${index}].Price" type="number" step="0.01" class="form-control" placeholder="0.00" required />
                </div>
                <div class="col-md-1">
                    <button type="button" class="btn btn-link text-danger p-0 remove-btn">
                        <i class="bi bi-dash-circle-fill" style="font-size: 1.5rem;"></i>
                    </button>
                </div>`;

            container.appendChild(newRow);
        }

                function reIndexItems() {
            document.querySelectorAll('.item-row').forEach((row, index) => {
                row.querySelectorAll('input, select').forEach(element => {
                    const name = element.getAttribute('name');
                    if (name) {
                        // This regex updates OrderItems[AnyNumber] to the current index
                        element.setAttribute('name', name.replace(/\[\d+\]/g, `[${index}]`));
                    }
                });
            });
        }

        // IMPORTANT: Your delete listener MUST call this
        document.addEventListener('click', function (e) {
            if (e.target.closest('.remove-btn')) {
                e.target.closest('.item-row').remove();
                reIndexItems(); // <--- This fixes the "Jam" bug
            }
        });
    </script>
}
