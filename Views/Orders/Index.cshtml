@model List<CoffeeShopMVC.Models.Order>

<main>
  <section class="card">
    <h2>Current Coffee Orders</h2>

    <table>
      <thead>
        <tr>
          <th>Order ID</th>
          <th>Customer</th>
          <th>Drink</th>
          <th>Size</th>
          <th>Quantity</th>
          <th>Total</th>
          <th>Actions</th>
        </tr>
      </thead>

      <tbody>
        @if (Model != null && Model.Any())
        {
          foreach (var order in Model)
          {
            <tr>
              <td>@order.Id</td>
              <td>@order.CustomerName</td>
              <td>@order.DrinkItem</td>
              <td>@order.Size</td>
              <td>@order.Quantity</td>
              <td>$@order.Total</td>
              <td>
                <a asp-action="Edit" asp-route-id="@order.Id">Edit</a> |
                <a asp-action="Delete" asp-route-id="@order.Id">Delete</a>
              </td>
            </tr>
          }
        }
        else
        {
          <tr>
            <td colspan="7">No orders found.</td>
          </tr>
        }
      </tbody>
    </table>

  </section>
</main>