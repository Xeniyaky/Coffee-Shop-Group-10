@model List<CoffeeShopMVC.Models.Order>

<main class="container mt-5">
    <section class="card p-4 shadow-sm">
        <h2 class="mb-4">Current Coffee Orders</h2>

        <div class="mb-3">
            <a asp-action="Create" class="btn btn-brown">Create New Order</a>
        </div>

        <div class="table-responsive shadow-sm" style="border-radius: 15px; overflow: hidden; border: 1px solid #e0e0e0;">
        <table class="table table-hover">
            <thead class="table-dark">
                <tr>
                    <th>Order ID</th>
                    <th>Customer</th>
                    <th>Main Item</th> <th>Total Qty</th> <th>Total Price</th>
                    <th>Date</th>
                    <th>Actions</th>
                </tr>
            </thead>

            <tbody>
                @if (Model != null && Model.Any())
                {
                    foreach (var order in Model)
                    {
                        <tr>
                            <td>@order.Id</td>
                            <td>@order.CustomerName</td>
                            <td>
                                @(order.OrderItems?.FirstOrDefault()?.DrinkName ?? "No items")
                                @(order.OrderItems?.Count > 1 ? $" (+{order.OrderItems.Count - 1} more)" : "")
                            </td>
                            <td>@order.OrderItems?.Sum(i => i.Quantity)</td>
                            <td>$@order.Total.ToString("F2")</td>
                            <td>@order.OrderDate.ToShortDateString()</td>
                            <td>
                                <td class="text-center">
                                    <a asp-action="Edit" asp-route-id="@order.Id" class="mx-2" style="color: #0d6efd;" title="Edit">
                                        <i class="bi bi-pencil-square" style="font-size: 1.2rem;"></i>
                                    </a>
                                    <a asp-action="Delete" asp-route-id="@order.Id" class="mx-2" style="color: #dc3545;" title="Delete">
                                        <i class="bi bi-trash3-fill" style="font-size: 1.2rem;"></i>
                                    </a>
                                </td>
                            </td>
                        </tr>
                    }
                }
                else
                {
                    <tr>
                        <td colspan="7" class="text-center">No orders found.</td>
                    </tr>
                }
            </tbody>
        </table>
        </div>
    </section>
</main>